{
  "name": "tenhou-probability-simulator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:py": "MPLCONFIGDIR=/tmp/mplconfig PYTHONPATH=. ./.venv/bin/python -m unittest discover -s backend/tests -v",
    "test:frontend": "cd frontend && npm test",
    "dev:py": "MPLCONFIGDIR=/tmp/mplconfig ./.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8888",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  }
}
